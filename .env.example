# Copia este archivo como .env y completa con tus valores reales.
# .env nunca se sube al repo (ver .gitignore).

# ─── Base de datos (obligatorio) ──────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ProyectoIngeneria
DB_USER=postgres
DB_PASSWORD=tu_password

# ─── Servidor (opcional, default 3000) ────────────────────────────────
PORT=3000

# ─── Autenticación JWT (opcional en desarrollo — auth.service.js trae
#     valores por defecto si se omiten, pero defínelos en producción) ──
JWT_SECRET=cambia_esta_clave_por_una_propia
JWT_EXPIRES_IN=8h

# ─── Correo transaccional (opcional — sin esto, los correos de
#     confirmación de pedido simplemente no se envían, el resto de la
#     app funciona igual) ──────────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=tu_correo@gmail.com
EMAIL_PASS=tu_app_password
EMAIL_FROM=tu_correo@gmail.com
